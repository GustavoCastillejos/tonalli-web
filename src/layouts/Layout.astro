---
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
}

const { description , title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<Header />
		<slot />
	</body>
</html>
<style is:global>
	html {
		font-family: "Onest Variable", system-ui, sans-serif;
		background: #ced4e2;
	}

	p{
		color: rgba(31, 30, 30, 0.9);
		line-heigh: 1.4;
		margin-bottom: 1em;
		font-weight: 100;
		font-size: 1m;
		letter-spacing: .5px;
	}

	p strong{
		color: black;
		font-weight: 700;
	}
</style>
