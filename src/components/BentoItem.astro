---
 interface Props{
    class?: string
    title: string
    subtitle?: string
 }
 
 const {title, subtitle} = Astro.props
---


<article class={`
    ${Astro.props.class}
    col-span-5
    relative rounded-xl
    blackdrop-blur-md
    border border-black/10
    shadow-inner shadow-white/10
    group
`}
>   
    <div 
    class="absolute z-10 bottom-0 top-0 w-full h-full
    bg-gradient-to-b from-transparent from-30% via-black/20 to-black/80"
    >
    </div>
    
    <slot name="image"></slot>

    <div class="relative select-nonte flex flex-col gap-1 p-6 text-lg z-20 justify-end h-full">
        <h2 class="text-3xl font-semibold text-balance text-white mb-4">{title}</h2>
        {subtitle && <h3>{subtitle}</h3>}
        <slot name="content"></slot>   
    </div>
</article>